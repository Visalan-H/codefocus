{
  "manifest_version": 3,
  "name": "CodeFocus",
  "version": "1.0.0",
  "description": "Turns Codeforces problem pages into a split view: run public samples instantly, submit without leaving the page.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://api.onlinecompiler.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CodeFocus"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/problemset/problem/*",
        "https://codeforces.com/contest/*/problem/*",
        "https://codeforces.com/gym/*/problem/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://codeforces.com/problemset/submit",
        "https://codeforces.com/contest/*/submit",
        "https://codeforces.com/gym/*/submit"
      ],
      "js": ["src/submit-page.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vs/*", "monaco-bootstrap.js", "src/*.js"],
      "matches": ["https://codeforces.com/*"]
    }
  ]
}
